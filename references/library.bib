@article{haoGHGEmissionsProduction2017,
  title = {{{GHG Emissions}} from the {{Production}} of {{Lithium-Ion Batteries}} for {{Electric Vehicles}} in {{China}}},
  author = {Hao, Han and Mu, Zhexuan and Jiang, Shuhua and Liu, Zongwei and Zhao, Fuquan},
  date = {2017-04},
  journaltitle = {Sustainability},
  volume = {9},
  number = {4},
  pages = {504},
  publisher = {Multidisciplinary Digital Publishing Institute},
  issn = {2071-1050},
  doi = {10.3390/su9040504},
  url = {https://www.mdpi.com/2071-1050/9/4/504},
  urldate = {2024-06-20},
  abstract = {With the mass market penetration of electric vehicles, the Greenhouse Gas (GHG) emissions associated with lithium-ion battery production has become a major concern. In this study, by establishing a life cycle assessment framework, GHG emissions from the production of lithium-ion batteries in China are estimated. The results show that for the three types of most commonly used lithium-ion batteries, the (LFP) battery, the (NMC) battery and the (LMO) battery, the GHG emissions from the production of a 28 kWh battery are 3061 kgCO2-eq, 2912 kgCO2-eq and 2705 kgCO2-eq, respectively. This implies around a 30\% increase in GHG emissions from vehicle production compared with conventional vehicles. The productions of cathode materials and wrought aluminum are the dominating contributors of GHG emissions, together accounting for around three quarters of total emissions. From the perspective of process energy use, around 40\% of total emissions are associated with electricity use, for which the GHG emissions in China are over two times higher than the level in the United States. According to our analysis, it is recommended that great efforts are needed to reduce the GHG emissions from battery production in China, with improving the production of cathodes as the essential measure.},
  issue = {4},
  langid = {english},
  keywords = {China,electric vehicle,greenhouse gas,life cycle assessment,lithium-ion battery},
  file = {/Users/jonaspamminger/Zotero/storage/RVJ46F9C/Hao et al. - 2017 - GHG Emissions from the Production of Lithium-Ion B.pdf}
}

