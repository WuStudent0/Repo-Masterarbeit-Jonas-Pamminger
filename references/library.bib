@incollection{zapfGesamtkostenNachTotal2019,
  title = {Gesamtkosten nach der Total Cost of Ownership Methodik (TCO) – Differenzierung nach Antriebsspezifischen Kosten},
  booktitle = {Kosteneffiziente und nachhaltige Automobile : Bewertung der realen Klimabelastung und der Gesamtkosten – Heute und in Zukunft},
  author = {Zapf, Martin and Pengg, Hermann and Bütler, Thomas and Bach, Christian and Weindl, Christian},
  editor = {Zapf, Martin and Pengg, Hermann and Bütler, Thomas and Bach, Christian and Weindl, Christian},
  date = {2019},
  pages = {209--243},
  publisher = {Springer Fachmedien},
  location = {Wiesbaden},
  doi = {10.1007/978-3-658-24060-8_5},
  url = {https://doi.org/10.1007/978-3-658-24060-8_5},
  urldate = {2024-06-20},
  abstract = {In diesem Kapitel werden die einzelnen Bestandteile der Gesamtkosten analysiert, die in Summe über den Lebensweg eines Fahrzeuges entstehen. Es werden die Kostenbestandteile nach der Total Cost of Ownership (TCO) Methodik für die Referenzfahrzeuge betrachtet. Für Standardfahrzeuge werden diejenigen Kostenbestandteile einer TCO-Analyse untersucht,welche als kennzeichnend für eine Antriebstechnologie gelten, als Gesamtkosten (TCO)exkl. Steuern und Versicherungen bezeichnet. Neben Steuern und Versicherungszahlungenbeinhalten diese Gesamtkosten auch keine Entsorgungs- bzw. Recyclingkosten. Die Energiepreise je Energieträger werden detailliert analysiert, aufgetrennt in die Kosten für Produktbeschaffung, Verteilung und Verkauf sowie Steuern. Die Energiekosten je Antriebstechnologie ergeben sich aus den Energiepreisen und dem Energieverbrauch der Fahrzeuge.},
  isbn = {978-3-658-24060-8},
  langid = {ngerman}
}
